datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  shop
  dropshipper
}

model User {
  id                 String              @id @default(uuid())
  name               String
  email              String              @unique
  passwordHash       String
  role               Role
  createdAt          DateTime            @default(now())
  shopListings       ShopListing[]
  dropshipperIntents DropshipperIntent[]
}

model ShopListing {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopName       String
  location       String
  rawProductText String
  description    String
  categories     String[]
  tags           String[]
  createdAt      DateTime @default(now())
}

model DropshipperIntent {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rawIntentText String
  categories    String[]
  tags          String[]
  createdAt     DateTime @default(now())
}
